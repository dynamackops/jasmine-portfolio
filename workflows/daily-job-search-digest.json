      ]
    },
    "Groq - AI Score Each Job": {
      "main": [[{ "node": "Format Scored Job Data (JavaScript)", "type": "main", "index": 0 }]]
    },
    "Format Scored Job Data (JavaScript)": {
      "main": [[{ "node": "Wait (rate limit buffer)", "type": "main", "index": 0 }]]
    },
    "Wait (rate limit buffer)": {
      "main": [[{ "node": "Append to Job Tracker Sheet", "type": "main", "index": 0 }]]
    },
    "Append to Job Tracker Sheet": {
